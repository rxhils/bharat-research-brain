# =====================================================================
# bharat-research-brain — environment template
# Copy this file to .env and fill in real values. .env is gitignored.
# =====================================================================

# === Postgres ===
# Generate a strong password and replace the placeholder below:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=bharat
POSTGRES_DB=bharat
POSTGRES_PASSWORD=replace_me_with_a_strong_password

# === POSTGRES_URL ===
# Default (backend running inside the Docker network):
POSTGRES_URL=postgresql+asyncpg://bharat:replace_me_with_a_strong_password@postgres:5432/bharat
# Host-machine alternative for local dev outside Docker:
# POSTGRES_URL=postgresql+asyncpg://bharat:replace_me_with_a_strong_password@localhost:5432/bharat

# === Redis ===
# Default (in Docker network):
REDIS_URL=redis://redis:6379/0
# Local dev: REDIS_URL=redis://localhost:6379/0

# === Ollama ===
# Default: backend container reaching host Ollama via the Docker host gateway.
OLLAMA_HOST=http://host.docker.internal:11434
# Local dev (Ollama on the same host): OLLAMA_HOST=http://localhost:11434

# === Broker (read-only scope) ===
FYERS_APP_ID=
FYERS_SECRET=
FYERS_REDIRECT_URI=
FYERS_ACCESS_TOKEN=

# === News ===
NEWSAPI_KEY=
MARKETAUX_KEY=
FMP_KEY=

# === Vault ===
VAULT_PATH=C:\claude\vault\rahil claude

# === Alerts ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# === App ===
# LOG_FORMAT: "console" for dev, "json" for production-style structured logs.
LOG_FORMAT=console
TZ=Asia/Kolkata
