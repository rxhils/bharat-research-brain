# Hosted Postgres (Neon) — read-only is enough for the dashboard.
# Wire real data by setting this + replacing the TODO queries in lib/data.ts.
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/bharat?sslmode=require

# Supabase — enables real Google sign-in (and chat persistence). Leave BOTH unset
# to run in mock/local mode (the auth gate uses a localStorage placeholder and the
# app never links out to Google). Publishable key is client-safe by design (RLS is
# the authorization boundary).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# --- API guard: durable rate limiting + quotas (see docs/MOBILE-API.md) ----------------------
# Upstash Redis REST (durable shared limiter). REQUIRED in production for /api/mobile/ask:
# without it the mobile route fails closed with SERVICE_UNAVAILABLE (never unlimited traffic).
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# Quota knobs (all optional; sensible defaults in lib/maven/apiGuard.ts).
# MOBILE_BURST_MAX=10             pre-auth IP burst per MOBILE_BURST_WINDOW_SEC (default 60s)
# MOBILE_USER_DAILY_MAX=150       per verified user per day
# MOBILE_DEEP_DAILY_MAX=10        deep-research class per user per day
# MOBILE_CONCURRENT_MAX=3         global concurrent deep-research requests
# WEB_ANON_BURST_MAX=30           web anonymous burst per minute
# API_BURST_PER_MIN=30            web authenticated burst per minute
# API_DAILY_CAP=150               web authenticated daily cap (usage_events)
# QUOTA_MODE=soft                 soft|strict - strict fails closed on meter infra errors
# RATE_LIMIT_ENABLED=             1|0; default: enforced on Vercel, off locally

# Rate-limit bypass for eval suites (send header x-maven-eval-token). Never bypasses auth.
MAVEN_EVAL_TOKEN=

# TEST-ONLY local auth for guard tests (hard-disabled whenever VERCEL is set). Never set in prod.
# MAVEN_TEST_AUTH_SECRET=
